---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={`關於我 | ${SITE_TITLE}`} description="關於我的介紹" />
	</head>
	<body>
		<Header />
		<main>
			<div class="flex flex-col md:flex-row gap-8 md:gap-16 items-start md:mt-8 w-full">
				<!-- 左邊：頭貼 + 簡介 -->
				<div class="flex flex-col items-center md:items-start w-full md:w-1/3 bg-primary/10 rounded-2xl p-6 md:p-14 overflow-hidden">
					<div class="w-40 h-40 md:w-50 md:h-50">
						<img
							src="/avatar.webp"
							alt="個人照片"
							class="w-full h-full object-cover rounded-full shadow-md"
						/>
					</div>
					<h1 class="font-bold text-2xl text-primary text-center md:text-left mt-6 mb-2">
						Hello, it's Jae!
					</h1>
					<p class="text-sm md:text-xl leading-relaxed">
						產地艋舺，插畫研究所畢業後轉往網頁開發的小小旅人，希望將所學以插畫的方式整理成有趣的筆記。</p>
					<div class="flex flex-row justify-center mt-2 gap-3">
						<a href="https://github.com/comea22" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center w-10 h-10 bg-primary text-white rounded-full hover:bg-secondary transition-colors">
							<svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
								<path d="M9 18c-4.51 2-5-2-7-2"/>
							</svg>
						</a>
						<a href="mailto:comea22@gmail.com" class="inline-flex items-center justify-center w-10 h-10 bg-primary text-white rounded-full hover:bg-secondary transition-colors">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
							</svg>
						</a>
					</div>
				</div>
				<!-- 右邊：技能 -->
				<div class="md:w-3/4">
					<div class="grid grid-cols-1 gap-8">
						<div>
							<h2 class="text-lg md:text-2xl font-bold text-primary mb-4">開發技能</h2>
							<p class="text-gray-dark">HTML / CSS / Tailwind CSS / JavaScript / Python / Django /  Git</p>
						</div>
						<div>
							<h2 class="text-lg md:text-2xl font-bold text-primary mb-4">其他技能</h2>
							<ul class="text-gray-dark space-y-4">
								<li>
									<span class="block font-semibold text-primary/70">Design Tools</span>
									Photoshop / Illustrator / Indesign / After Effects / Procreate
								</li>
								<li>
									<span class="block font-semibold text-primary/70">Creative Services</span>
									展覽主視覺 / 插畫 / LOGO 設計 / 包裝設計 / 書籍排版 / 印刷
								</li>
							</ul>
						</div>
						<div>
							<h2 class="text-lg md:text-2xl font-bold text-primary mb-4">特殊經歷</h2>
							<ul class="text-gray-dark">
								<li>具備馬桶維修經驗</li>
								<li>精通台語，托福 iBT 92 分</li>
								<li>
									<p>不怕蟑螂，無法活捉，但善於消滅</p>
									<button id="open-modal" class="inline-flex items-center gap-1 px-4 py-2 md:px-5 md:py-2.5 text-base md:text-lg text-primary rounded-2xl border border-gray-200 shadow-md hover:bg-secondary hover:text-white transition-all mt-1.5 cursor-pointer mb-4 md:mb-0">
										<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
											<path d="M12 20v-8"/>
											<path d="M14.12 3.88 16 2"/>
											<path d="M15 7.13V6a3 3 0 0 0-5.14-2.1L8 2"/>
											<path d="M18 12.34V11a4 4 0 0 0-4-4h-1.3"/>
											<path d="m2 2 20 20"/>
											<path d="M21 5a4 4 0 0 1-3.55 3.97"/>
											<path d="M22 13h-3.34"/>
											<path d="M3 21a4 4 0 0 1 3.81-4"/>
											<path d="M6 13H2"/>
											<path d="M7.7 7.7A4 4 0 0 0 6 11v3a6 6 0 0 0 11.13 3.13"/>
										</svg>
										預約滅蟑
									</button>
								</li>
							</ul>
						</div>
					</div>
				</div>
			</div>
		</main>
		<Footer />

		<!-- Modal -->
		<div id="modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80">
			<div class="relative bg-white rounded-2xl shadow-lg py-6 px-8 mx-4 max-w-md text-center">
				<button id="close-modal" class="absolute top-3 right-3 text-gray hover:text-primary transition-colors cursor-pointer">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>
				<p class="text-6xl py-6">🦤</p>
				<div class="text-sm md:text-base">
				<p >謝謝你的好奇心，</p>
				<p>等未來某天被 AI 取代，就會開放這個消滅實體 Bug 的服務</p>
				<p>在此先附上折扣碼：<span class="font-bold text-primary">404NOTFOUND</span></p>
				</div>
				
			</div>
		</div>

		<script>
			const openBtn = document.getElementById('open-modal');
			const closeBtn = document.getElementById('close-modal');
			const modal = document.getElementById('modal');

			openBtn?.addEventListener('click', () => {
				modal?.classList.remove('hidden');
				modal?.classList.add('flex');
			});

			closeBtn?.addEventListener('click', () => {
				modal?.classList.add('hidden');
				modal?.classList.remove('flex');
			});

			modal?.addEventListener('click', (e) => {
				if (e.target === modal) {
					modal.classList.add('hidden');
					modal.classList.remove('flex');
				}
			});
		</script>
	</body>
</html>
